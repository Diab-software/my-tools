#!/bin/bash

# === sys-info: عرض معلومات الجهاز ===

GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}📱 معلومات الجهاز${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# البطارية (إن وجدت)
if command -v termux-battery-status &>/dev/null; then
    echo -e "${YELLOW}🔋 البطارية:${NC}"
    termux-battery-status | grep -E 'percentage|status|temperature' | sed 's/^/  /'
fi

# الذاكرة
echo -e "\n${YELLOW}🧠 الذاكرة:${NC}"
free -h | grep -E 'Mem|Swap' | sed 's/^/  /'

# المساحة
echo -e "\n${YELLOW}💾 المساحة:${NC}"
df -h /data | grep -v Filesystem | sed 's/^/  /'

# المعالج
echo -e "\n${YELLOW}⚙️ المعالج:${NC}"
grep -E 'model name|processor' /proc/cpuinfo 2>/dev/null | head -2 | sed 's/^/  /'

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
