#!/bin/bash

# === yt-dl: تحميل فيديوهات يوتيوب (صوت/فيديو) ===

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

if [ -z "$1" ]; then
    echo -e "${YELLOW}الاستخدام:${NC}"
    echo "  yt-dl <رابط>        ← تحميل فيديو (جودة عالية)"
    echo "  yt-dl -a <رابط>     ← تحميل صوت فقط (MP3)"
    echo "  yt-dl -p <قائمة>    ← تحميل قائمة تشغيل"
    exit 1
fi

case "$1" in
    -a)
        echo -e "${GREEN}🎵 جارٍ تحميل الصوت...${NC}"
        yt-dlp -f bestaudio --extract-audio --audio-format mp3 --audio-quality 0 "$2"
        ;;
    -p)
        echo -e "${GREEN}📂 جارٍ تحميل القائمة...${NC}"
        yt-dlp -f bestvideo+bestaudio --merge-output-format mp4 "$2"
        ;;
    *)
        echo -e "${GREEN}🎬 جارٍ تحميل الفيديو...${NC}"
        yt-dlp -f bestvideo+bestaudio --merge-output-format mp4 "$1"
        ;;
esac

if [ $? -eq 0 ]; then
    echo -e "${GREEN}✅ التحميل انتهى بنجاح!${NC}"
else
    echo -e "${RED}✖ فشل التحميل، تأكد من الرابط والإنترنت.${NC}"
fi
