#!/bin/bash
# === db-query: استعلامات قاعدة بيانات سريعة ===

if [ -z "$1" ] || [ -z "$2" ]; then
    echo "الاستخدام: db-query <sqlite|mysql> <استعلام> [قاعدة_بيانات]"
    echo "مثال: db-query sqlite 'SELECT * FROM users' mydb.db"
    echo "مثال: db-query mysql 'SHOW TABLES' mydb"
    exit 1
fi

DB_TYPE=$1
QUERY=$2
DB_NAME=$3

case $DB_TYPE in
    sqlite)
        if [ -z "$DB_NAME" ]; then
            echo "✖ حدد ملف قاعدة البيانات (.db)"
            exit 1
        fi
        sqlite3 "$DB_NAME" "$QUERY" -header -column
        ;;
    mysql)
        if [ -z "$DB_NAME" ]; then
            echo "✖ حدد اسم قاعدة البيانات"
            exit 1
        fi
        # يستخدم المستخدم الحالي وكلمة السر من ~/.my.cnf (اختياري)
        mysql -u "$USER" -p "$DB_NAME" -e "$QUERY" 2>/dev/null || echo "⚠️ فشل الاتصال بـ MySQL"
        ;;
    *)
        echo "✖ نوع غير مدعوم: $DB_TYPE (استخدم sqlite أو mysql)"
        ;;
esac
