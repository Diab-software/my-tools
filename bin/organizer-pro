#!/bin/bash
# === organizer-pro: ترتيب الملفات مع إحصائيات ===

if [ -z "$1" ]; then
    echo "الاستخدام: organizer-pro <المجلد>"
    exit 1
fi

TARGET="$1"
if [ ! -d "$TARGET" ]; then
    echo "✖ المجلد غير موجود"
    exit 1
fi

cd "$TARGET" || exit

declare -A EXT_MAP=(
    [Images]="jpg jpeg png gif bmp svg webp"
    [Videos]="mp4 mkv avi mov wmv flv webm"
    [Documents]="pdf doc docx txt xls xlsx ppt pptx odt md"
    [Archives]="zip tar gz rar 7z"
    [Scripts]="sh py js php rb pl go rs"
    [Audios]="mp3 wav flac aac ogg"
)

TOTAL=0
for type in "${!EXT_MAP[@]}"; do
    mkdir -p "$type"
done

for file in *; do
    [ -f "$file" ] || continue
    ext="${file##*.}"
    ext_lower=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
    MOVED=0
    for type in "${!EXT_MAP[@]}"; do
        if [[ "${EXT_MAP[$type]}" == *"$ext_lower"* ]]; then
            mv "$file" "$type/" 2>/dev/null && MOVED=1 && ((TOTAL++))
            break
        fi
    done
    if [ $MOVED -eq 0 ]; then
        mkdir -p Others
        mv "$file" Others/ 2>/dev/null && ((TOTAL++))
    fi
done

echo "✅ تم تنظيم $TOTAL ملفاً في $TARGET"
du -sh */ 2>/dev/null | sort -hr
