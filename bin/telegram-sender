#!/bin/bash
# === telegram-sender: إرسال رسالة عبر بوت التيليجرام ===

# عوّض التوكن والـ chat ID هنا
TOKEN="ضع_التوكن_هنا"
CHAT_ID="ضع_رقم_الشات_هنا"

if [ -z "$1" ]; then
    echo "الاستخدام: telegram-sender \"نص الرسالة\""
    exit 1
fi

MESSAGE="$1"
curl -s -X POST "https://api.telegram.org/bot$TOKEN/sendMessage" \
    -d chat_id="$CHAT_ID" \
    -d text="$MESSAGE" > /dev/null

if [ $? -eq 0 ]; then
    echo "✅ تم إرسال الرسالة"
else
    echo "✖ فشل الإرسال، تحقق من التوكن والإنترنت"
fi
