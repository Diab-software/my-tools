#!/bin/bash

# === organizer: تنظيم الملفات حسب النوع ===

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

if [ -z "$1" ]; then
    echo -e "${RED}✖ خطأ: حدد المجلد المراد تنظيمه${NC}"
    echo -e "${YELLOW}الاستخدام: organizer <المجلد>${NC}"
    exit 1
fi

TARGET="$1"
if [ ! -d "$TARGET" ]; then
    echo -e "${RED}✖ المجلد غير موجود: $TARGET${NC}"
    exit 1
fi

cd "$TARGET"

# تعريف الأنواع
declare -A TYPES=(
    [Images]="jpg jpeg png gif bmp svg webp"
    [Videos]="mp4 mkv avi mov wmv flv webm"
    [Documents]="pdf doc docx txt xls xlsx ppt pptx odt"
    [Archives]="zip tar gz rar 7z"
    [Scripts]="sh py js php rb pl"
    [Audios]="mp3 wav flac aac ogg"
    [Others]="*"
)

echo -e "${GREEN}📂 بدء تنظيم المجلد: $TARGET${NC}"

# إنشاء المجلدات حسب الأنواع
for type in "${!TYPES[@]}"; do
    mkdir -p "$type"
done

# نقل الملفات
MOVED=0
for file in *; do
    [ -f "$file" ] || continue
    ext="${file##*.}"
    ext_lower=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
    moved=0
    for type in "${!TYPES[@]}"; do
        if [[ "${TYPES[$type]}" == *"$ext_lower"* ]]; then
            mv "$file" "$type/" 2>/dev/null
            if [ $? -eq 0 ]; then
                echo "  → $file → $type/"
                ((MOVED++))
                moved=1
                break
            fi
        fi
    done
    if [ $moved -eq 0 ] && [ "$type" != "Others" ]; then
        mv "$file" Others/ 2>/dev/null
        if [ $? -eq 0 ]; then
            echo "  → $file → Others/"
            ((MOVED++))
        fi
    fi
done

echo -e "${GREEN}✅ تم نقل $MOVED ملفاً بنجاح.${NC}"
