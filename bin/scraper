#!/bin/bash

# === scraper: استخراج عناوين وروابط من صفحة ويب ===

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

if [ -z "$1" ]; then
    echo -e "${RED}✖ خطأ: حدد رابط الموقع${NC}"
    echo -e "${YELLOW}الاستخدام: scraper <URL> [--links]${NC}"
    echo "  مثال: scraper https://example.com"
    echo "  مثال: scraper https://example.com --links  (لعرض الروابط فقط)"
    exit 1
fi

URL=$1
MODE=${2:-"titles"}

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${YELLOW}🌐 جارٍ جلب البيانات من: ${BLUE}$URL${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# جلب الصفحة
HTML=$(curl -s -L "$URL")

if [ -z "$HTML" ]; then
    echo -e "${RED}✖ فشل جلب الصفحة. تأكد من الرابط والاتصال.${NC}"
    exit 1
fi

if [ "$MODE" == "--links" ]; then
    # استخراج جميع الروابط (href)
    echo -e "${GREEN}📎 الروابط الموجودة:${NC}"
    echo "$HTML" | grep -oE 'href="[^"]*"' | cut -d'"' -f2 | grep -v '^#' | sort -u | while read link; do
        echo "  - $link"
    done
else
    # استخراج العناوين (h1, h2, h3)
    echo -e "${GREEN}📰 العناوين الرئيسية:${NC}"
    echo "$HTML" | grep -oE '<h[1-3][^>]*>.*</h[1-3]>' | sed 's/<[^>]*>//g' | while read title; do
        echo "  • $title"
    done
fi

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}✅ انتهى الاستخراج!${NC}"
